{
  "expo": {
    "name": "Melani Scan",
    "slug": "melaniscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Melanin.png",
    "scheme": "melaninscan",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.melaninscan.app",
      "buildNumber": "1.0",
      "infoPlist": {
        "NSCameraUsageDescription": "Melanin Scan uses your camera to capture skin images for analysis. Camera access is only activated when you choose to take a photo.",
        "NSPhotoLibraryUsageDescription": "Melanin Scan needs access to your photo library to upload skin images for analysis. Photo access is optional.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.melaninscan.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1A1A2E",
        "foregroundImage": "./assets/Melanin.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": []
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/Melanin.png",
          "color": "#1A1A2E",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Melanin Scan uses your camera to capture skin images for analysis. Camera access is only activated when you choose to take a photo.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Melanin Scan needs access to your photo library to upload skin images for analysis. Photo access is optional.",
          "cameraPermission": "Melanin Scan uses your camera to capture skin images for analysis."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/Melanin.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "enableProguardInReleaseBuilds": true,
            "usesCleartextTraffic": false,
            "enableMinifyInReleaseBuilds": true
          },
          "ios": {
            "deploymentTarget": "15.4"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c2d9dd3d-89ff-446c-aaae-83de8bf3ac92"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "owner": "tezzer"
  }
}
